generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  image           String?
  scoutSessions   ScoutSession[]
  savedProperties SavedProperty[]
  createdAt       DateTime        @default(now())
}

model ScoutSession {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  location     String
  bounds       String?
  filters      String?
  totalScanned Int               @default(0)
  totalFlagged Int               @default(0)
  hotDeals     Int               @default(0)
  duration     Int?
  status       String            @default("running")
  properties   ScoutedProperty[]
  createdAt    DateTime          @default(now())
  completedAt  DateTime?

  @@index([userId, createdAt])
}

model ScoutedProperty {
  id                String       @id @default(cuid())
  scoutSessionId    String
  scoutSession      ScoutSession @relation(fields: [scoutSessionId], references: [id], onDelete: Cascade)
  propertyId        String?
  propertyUrl       String?
  address           String
  city              String
  state             String
  zipCode           String
  latitude          Float?
  longitude         Float?
  listPrice         Int?
  estimatedValue    Int?
  soldPrice         Int?
  sqft              Int?
  beds              Int?
  baths             Float?
  yearBuilt         Int?
  lotSqft           Int?
  daysOnMls         Int?
  propertyType      String?
  listingStatus     String?
  pricePerSqft      Float?
  taxAssessedValue  Int?
  hoaFee            Int?
  description       String?
  photos            String?
  primaryPhoto      String?
  rawData           String?
  source            String?
  distressScore     Int?
  distressSignals   String?
  aiReasoning       String?
  aiConfidence      Int?
  propertyCondition String?
  createdAt         DateTime     @default(now())

  @@unique([scoutSessionId, propertyId])
  @@index([distressScore])
  @@index([scoutSessionId])
}

/// Cache visual analysis results so re-scouting the same area
/// doesn't re-fetch imagery or re-analyze unchanged properties.
model VisualAnalysisCache {
  id                 String   @id @default(cuid())
  propertyId         String   @unique
  latitude           Float
  longitude          Float
  distressScore      Int
  signals            String
  condition          String
  notes              String
  imageCount         Int      @default(0)
  analyzedAt         DateTime @default(now())

  @@index([latitude, longitude])
}

model SavedProperty {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  scoutedPropertyId String?
  address           String
  city              String
  state             String
  zipCode           String
  latitude          Float?
  longitude         Float?
  listPrice         Int?
  distressScore     Int?
  aiReasoning       String?
  distressSignals   String?
  photos            String?
  primaryPhoto      String?
  allData           String?
  pipelineStage     String   @default("scouted")
  tags              String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, pipelineStage])
  @@index([userId, distressScore])
}
